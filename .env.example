# Скопируй в `.env` и заполни перед `docker compose up`.
# Если YT2MP3_AUTH_USER и YT2MP3_AUTH_PASS заданы — на сайте появится
# страница логина. Иначе сайт открыт всем (только для локального запуска!).

YT2MP3_AUTH_USER=admin
YT2MP3_AUTH_PASS=

# Подписывает session-cookie. Если не задать — будет генериться случайно
# при каждом рестарте, и тебя будет выбивать с залогина после рестарта.
# Сгенерировать: openssl rand -base64 48
YT2MP3_SECRET_KEY=
