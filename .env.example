# Скопируй в `.env` и заполни перед `docker compose up`.
#
# По умолчанию сайт ОТКРЫТ всем — логин не нужен. Если задать
# YT2MP3_AUTH_USER и YT2MP3_AUTH_PASS, появится админ-панель (/admin) и в ней
# переключатель «требовать логин для всего сайта» (состояние хранится в БД,
# переживает рестарт). Удаление файлов и аналитика по IP всегда только для админа.

YT2MP3_AUTH_USER=admin
YT2MP3_AUTH_PASS=

# Подписывает session-cookie. Если не задать — будет генериться случайно
# при каждом рестарте, и тебя будет выбивать с залогина после рестарта.
# Сгенерировать: openssl rand -base64 48
YT2MP3_SECRET_KEY=

# --- HTTPS через Caddy (docker-compose.yml) ---
# Домен, на который Caddy получит Let's Encrypt сертификат. Должен указывать
# A/AAAA записью на этот сервер. Порты 80/443 должны быть открыты.
DOMAIN=yt2mp3.example.com
